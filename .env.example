# Copy to .env and adjust as needed. .env is gitignored.

# Log level: debug | info | warn | error =================================
LOG_LEVEL=info

# Log format: text | json ================================================
LOG_FORMAT=text
#LOG_DIR=logs

# LLM Provider API Keys: ==================================================
## Anthropic
ANTHROPIC_API_KEY=***
## DEEPSEEK
DEEPSEEK_API_KEY=***
## OpenAI
OPENAI_API_KEY=***

# General Settings: ==================================================
## UI
DISPLAY_THINKING=true

## Agent loop / LLM defaults (overridable per-run via -max-iters / -max-tokens flags).
#DEFAULT_MAX_ITERATIONS=25
#DEFAULT_MAX_TOKENS=4096

# Web Tools: ==============================================================
## Tavily API key — required for the web_search tool. Get one at https://tavily.com.
## When unset, web_search returns a "not configured" error instead of crashing.
TAVILY_API_KEY=***
## Cap on chars returned by web_fetch (default 100000). Raise for long docs.
#FETCH_MAX_BYTES=100000
